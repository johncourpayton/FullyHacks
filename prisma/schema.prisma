generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContaminationPocket {
  id          String @id @default(cuid())
  type        String
  severity    Int
  geometry    Json
  description String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contamination_pockets")
}

model MigrationPath {
  id          String   @id @default(cuid())
  speciesName String
  timestamp   DateTime
  path        Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("migration_paths")
}
